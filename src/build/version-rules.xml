<?xml version="1.0" encoding="UTF-8"?>
<ruleset comparisonMethod="maven"
         xmlns="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://mojo.codehaus.org/versions-maven-plugin/rule/2.0.0
                             https://www.mojohaus.org/versions/versions-maven-plugin/xsd/rule-2.0.0.xsd">
    <ignoreVersions>
        <!-- Exclude pre-release versions: alpha, beta, milestone, RC, dev, snapshot -->
        <ignoreVersion type="regex">(?i).*(alpha|beta|milestone|rc|m\d|\-dev|\-snapshot).*</ignoreVersion>
    </ignoreVersions>
    <rules>
        <rule groupId="org.junit.jupiter">
            <!-- JUnit 6+ requires a newer surefire provider not yet available -->
            <ignoreVersions>
                <ignoreVersion type="regex">^[6-9]\..*</ignoreVersion>
            </ignoreVersions>
        </rule>
    </rules>
</ruleset>
